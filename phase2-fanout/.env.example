# Chế độ token: 'custom' (8 app riêng — ĐÃ CHỐT) | 'isv' (1 app cài 8 org)
PROVIDER_MODE=custom

# Host Lark (Larksuite quốc tế)
LARK_HOST=https://open.larksuite.com

# --- ISV mode (chỉ cần khi PROVIDER_MODE=isv) ---
# app_id/secret của 1 app ISV. app_ticket KHÔNG để ở đây — Lark push qua event, lưu .data/app_ticket.json
ISV_APP_ID=cli_xxxxxxxxxxxx
ISV_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- CUSTOM mode (chỉ cần khi PROVIDER_MODE=custom) ---
# cp config/credentials.example.json config/credentials.json rồi điền 8 bộ (app_id, app_secret)
# CREDENTIALS_FILE=./config/credentials.json
